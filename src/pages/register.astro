---
import Layout from '../layouts/Layout.astro';
---
<Layout title="新規登録 | 九星気学">
  <div class="page">
    <div class="page-inner">
      <h1 class="page-title">新規登録</h1>

      <div class="card">
        <div class="field">
          <label>メールアドレス</label>
          <input type="email" id="email" placeholder="example@email.com" />
        </div>
        <div class="field">
          <label>パスワード</label>
          <input type="password" id="password" placeholder="8文字以上" />
        </div>
        <div class="field">
          <label>生年月日</label>
          <div class="date-row">
            <input type="number" id="year" placeholder="1990" min="1900" max="2010" />
            <select id="month">
              {Array.from({length:12},(_,i)=>(
                <option value={i+1}>{i+1}月</option>
              ))}
            </select>
            <select id="day">
              {Array.from({length:31},(_,i)=>(
                <option value={i+1}>{i+1}日</option>
              ))}
            </select>
          </div>
        </div>
        <p class="error-msg" id="error"></p>
        <button class="btn-primary" id="register-btn" onclick="doRegister()">登録する</button>
        <p class="switch-link">すでにアカウントをお持ちの方は<a href="/login">ログイン</a></p>
      </div>
    </div>
  </div>
</Layout>

<style>
.page { padding: 4rem 1.5rem; }
.page-inner { max-width: 400px; margin: 0 auto; }
.page-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 24px; text-align: center; margin-bottom: 2rem;
}
.card { display: flex; flex-direction: column; gap: 1rem; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 12px; color: var(--text-secondary); }
.date-row { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 8px; }
.switch-link { font-size: 13px; color: var(--text-secondary); text-align: center; }
</style>

<script>
const WORKERS_URL = import.meta.env.PUBLIC_WORKERS_URL;

async function doRegister() {
  const email = (document.getElementById('email') as HTMLInputElement).value;
  const password = (document.getElementById('password') as HTMLInputElement).value;
  const year = (document.getElementById('year') as HTMLInputElement).value;
  const month = (document.getElementById('month') as HTMLSelectElement).value;
  const day = (document.getElementById('day') as HTMLSelectElement).value;
  const errEl = document.getElementById('error')!;
  const btn = document.getElementById('register-btn') as HTMLButtonElement;

  if (!email || !password || !year) { errEl.textContent = '全ての項目を入力してください'; return; }
  if (password.length < 8) { errEl.textContent = 'パスワードは8文字以上にしてください'; return; }
  if (parseInt(year) < 1900 || parseInt(year) > 2010) { errEl.textContent = '生年を正しく入力してください'; return; }
  errEl.textContent = '';
  btn.textContent = '登録中...'; btn.disabled = true;

  const birth_date = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;

  try {
    const res = await fetch(`${WORKERS_URL}/api/auth/register`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password, birth_date }),
    });
    const data = await res.json() as any;
    if (!res.ok) { errEl.textContent = data.error; return; }
    localStorage.setItem('kyusei_token', data.token);
    localStorage.setItem('kyusei_user', JSON.stringify(data.user));
    window.location.href = '/mypage';
  } catch {
    errEl.textContent = 'エラーが発生しました。しばらくしてお試しください。';
  } finally {
    btn.textContent = '登録する'; btn.disabled = false;
  }
}
</script>
