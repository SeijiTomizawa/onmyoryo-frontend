---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ログイン | 九星気学">
  <div class="page">
    <div class="page-inner">
      <h1 class="page-title">ログイン</h1>

      <div class="card">
        <div class="field">
          <label>メールアドレス</label>
          <input type="email" id="email" placeholder="example@email.com" />
        </div>
        <div class="field">
          <label>パスワード</label>
          <input type="password" id="password" placeholder="••••••••" />
        </div>
        <p class="error-msg" id="error"></p>
        <button class="btn-primary" id="login-btn" onclick="doLogin()">ログイン</button>
        <p class="switch-link">アカウントをお持ちでない方は<a href="/register">新規登録</a></p>
      </div>
    </div>
  </div>
</Layout>

<style>
.page { padding: 4rem 1.5rem; }
.page-inner { max-width: 400px; margin: 0 auto; }
.page-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 24px; text-align: center; margin-bottom: 2rem;
}
.card { display: flex; flex-direction: column; gap: 1rem; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 12px; color: var(--text-secondary); }
.switch-link { font-size: 13px; color: var(--text-secondary); text-align: center; }
</style>

<script>
const WORKERS_URL = import.meta.env.PUBLIC_WORKERS_URL;

async function doLogin() {
  const email = (document.getElementById('email') as HTMLInputElement).value;
  const password = (document.getElementById('password') as HTMLInputElement).value;
  const errEl = document.getElementById('error')!;
  const btn = document.getElementById('login-btn') as HTMLButtonElement;

  if (!email || !password) { errEl.textContent = 'メールアドレスとパスワードを入力してください'; return; }
  errEl.textContent = '';
  btn.textContent = '確認中...'; btn.disabled = true;

  try {
    const res = await fetch(`${WORKERS_URL}/api/auth/login`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password }),
    });
    const data = await res.json() as any;
    if (!res.ok) { errEl.textContent = data.error; return; }
    localStorage.setItem('kyusei_token', data.token);
    localStorage.setItem('kyusei_user', JSON.stringify(data.user));
    window.location.href = '/mypage';
  } catch {
    errEl.textContent = 'エラーが発生しました。しばらくしてお試しください。';
  } finally {
    btn.textContent = 'ログイン'; btn.disabled = false;
  }
}
</script>
