---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="特定商取引法に基づく表記 | 陰陽寮">
  <div class="page legal-page">
    <div class="page-inner">
      <header class="page-header fade-in-up">
        <h1 class="page-title">特定商取引法に基づく表記</h1>
      </header>

      <div class="glass-card legal-content fade-in-up delay-1">
        
        <table class="law-table">
          <tbody>
            <tr>
              <th>販売事業者名</th>
              <td>電究社</td>
            </tr>
            <tr>
              <th>運営責任者</th>
              <td>富澤 聖児</td>
            </tr>
            <tr>
              <th>所在地</th>
              <td>お客様からのご請求に基づき、遅滞なく開示いたします</td>
            </tr>
            <tr>
              <th>電話番号</th>
              <td>お客様からのご請求に基づき、遅滞なく開示いたします</td>
            </tr>
            <tr>
              <th>メールアドレス</th>
              <td>support@denkyusha.com</td>
            </tr>
            <tr>
              <th>販売価格</th>
              <td>購入手続き画面にて表示する価格（消費税込）となります。</td>
            </tr>
            <tr>
              <th>商品代金以外の必要料金</th>
              <td>当サイトのページの閲覧、サービス利用等に必要となるインターネット接続料金、通信料金は、お客様のご負担となります。</td>
            </tr>
            <tr>
              <th>支払方法および支払時期</th>
              <td>クレジットカード決済（商品注文時点でお支払いが確定いたします）</td>
            </tr>
            <tr>
              <th>商品の引渡時期（サービスの提供時期）</th>
              <td>決済手続完了後、直ちにご利用いただけます（コインの即時付与）。</td>
            </tr>
            <tr>
              <th>返品・キャンセルについて</th>
              <td>デジタルコンテンツという商品の特性上、購入後のお客様の都合による返品、返金、キャンセルについてはお受けできません。</td>
            </tr>
          </tbody>
        </table>

      </div>
    </div>
  </div>
</Layout>

<style>
/* 共通スタイル */
.legal-page { padding: 4rem 1.5rem; }
.legal-content { padding: 3rem; color: var(--text-main); line-height: 2; font-size: 0.95rem; }

/* 特商法用のテーブルスタイル */
.law-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 1rem;
}
.law-table th, .law-table td {
  padding: 1.5rem 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  text-align: left;
  vertical-align: top;
}
.law-table th {
  width: 30%;
  color: var(--gold);
  font-weight: normal;
}
.law-table td {
  width: 70%;
  color: var(--text-main);
}
@media (max-width: 600px) {
  .legal-content { padding: 1.5rem; }
  .law-table th, .law-table td {
    display: block;
    width: 100%;
    padding: 0.8rem 0;
  }
  .law-table th { padding-bottom: 0; border-bottom: none; }
  .law-table td { padding-top: 0.2rem; }
}
</style>