---
import Layout from '../layouts/Layout.astro';
---

<Layout title="九星気学鑑定 | 東洋占術">
  <style is:global>
    :root {
      --bg-dark: #0a0c10;
      --bg-gradient: radial-gradient(circle at top, #1a1c2e 0%, #050508 100%);
      --gold: #d4af37;
      --gold-light: #f9e596;
      --text-main: #e2e8f0;
      --text-secondary: #94a3b8;
      --glass-bg: rgba(20, 24, 39, 0.4);
      --glass-border: rgba(212, 175, 55, 0.15);
      --radius-lg: 16px;
      --font-mincho: 'Shippori Mincho', 'Noto Serif JP', serif;
      --font-sans: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', sans-serif;
    }
    body {
      background: var(--bg-gradient);
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: var(--font-sans);
      line-height: 1.8;
      margin: 0;
    }
  </style>

  <div class="hero">
    <div class="stars" id="stars"></div>
    <div class="hero-content">
      <p class="eyebrow">東洋占術 · 九星気学</p>
      <h1 class="hero-title">生年月日が示す<br/>あなたの本質と運命</h1>
      <p class="hero-desc">
        古来より伝わる「気」の統計学。<br>本命星・月命星・吉方位を読み解き、人生の羅針盤を手に入れる。
      </p>
      <a href="/fortune" class="btn-primary hero-btn">無料で鑑定する</a>
      <p class="hero-note">
        ※無料鑑定では本命星のみ表示されます。<br>月命星や吉方位、年運・月運の詳細鑑定はコインが必要です。
      </p>
    </div>
    <div class="scroll-indicator">
      <span>Scroll</span>
    </div>
  </div>

  <section class="content-section">
    <div class="content-inner text-center fade-in-up">
      <h2 class="section-title">幸せへの最短ルートを見つける。<br>「九星気学」の世界へようこそ</h2>
      <p class="lead-text">
        「なんだか最近、タイミングが悪いな」<br>
        「自分にぴったりの環境や、運気が上がる場所を知りたい」
      </p>
      <p class="text-muted">
        もしあなたがそう感じているなら、九星気学がその答えを教えてくれるかもしれません。<br>
        九星気学は、古代中国から伝わる「気（エネルギー）」の統計学です。<br>
        私たちが生まれた瞬間に吸い込んだ地球のエネルギーを、「一白水星」から「九紫火星」まで9つの星に分類し、あなたの宿命や運気のバイオリズムを驚くほど鮮明に描き出します。
      </p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <div class="text-center mb-3 fade-in-up">
        <h3 class="section-subtitle">九星気学で何がわかるの？</h3>
        <p class="text-muted">九星気学の最大の特徴は、ただ「運勢を待つ」のではなく、自ら「運を掴みに行く」ことができる点にあります。</p>
      </div>
      <div class="grid-cards">
        <div class="glass-card fade-in-up delay-1">
          <h4>✧ あなたの「本質」と「才能」</h4>
          <p>自分でも気づいていない強みや、人生で直面しやすい課題がわかります。</p>
        </div>
        <div class="glass-card fade-in-up delay-2">
          <h4>✧ 動くべき「最高のタイミング」</h4>
          <p>転職、結婚、大きな買い物。いつ動けば追い風に乗れるのか、その時期を特定します。</p>
        </div>
        <div class="glass-card fade-in-up delay-3">
          <h4>✧ 最強のパワースポット「吉方位」</h4>
          <p>「どの方向へ行けば運気が上がるのか？」という方位学の知恵を使い、運気を劇的に改善する「祐気取り」の実践が可能です。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section alternate-bg">
    <div class="content-inner">
      <div class="text-center mb-3 fade-in-up">
        <h3 class="section-subtitle">九つの星、あなたはどのタイプ？</h3>
        <p class="text-muted">宇宙のエネルギーは、以下の9つの個性に分かれます。</p>
      </div>
      <div class="stars-grid fade-in-up delay-1">
        <dl class="star-list">
          <div class="star-item"><dt>一白水星</dt><dd>柔軟で芯が強い、静かなる知略家</dd></div>
          <div class="star-item"><dt>二黒土星</dt><dd>献身的で誠実、大地のような包容力</dd></div>
          <div class="star-item"><dt>三碧木星</dt><dd>若々しく行動的、アイデア溢れる開拓者</dd></div>
          <div class="star-item"><dt>四緑木星</dt><dd>社交的で穏やか、良縁を呼び込む風のよう</dd></div>
          <div class="star-item"><dt>五黄土星</dt><dd>圧倒的な存在感、逆境を跳ね返す帝王</dd></div>
          <div class="star-item"><dt>六白金星</dt><dd>高い志と正義感、完璧を求めるリーダー</dd></div>
          <div class="star-item"><dt>七赤金星</dt><dd>華やかで多才、人生を楽しむ悦びの象徴</dd></div>
          <div class="star-item"><dt>八白土星</dt><dd>粘り強く着実、変化を力に変える改革者</dd></div>
          <div class="star-item"><dt>九紫火星</dt><dd>情熱的で先見の明がある、美と知性の人</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="features-inner">
      <div class="feature-card glass-card fade-in-up delay-1">
        <div class="feature-icon">☽</div>
        <h3>本命星・月命星</h3>
        <p>生年月日から本命星と月命星を算出。あなたの本質的な性格と内面を照らします。</p>
      </div>
      <div class="feature-card glass-card fade-in-up delay-2">
        <div class="feature-icon">◈</div>
        <h3>吉方位・凶方位</h3>
        <p>引越し・旅行・就職など重要な決断に役立つ方位をお伝えします。</p>
      </div>
      <div class="feature-card glass-card fade-in-up delay-3">
        <div class="feature-icon">◎</div>
        <h3>年運・月運</h3>
        <p>今年の運気の流れと月ごとの吉凶を詳しく鑑定します。</p>
      </div>
    </div>
  </section>

  <section class="cta fade-in-up">
    <div class="cta-inner glass-card text-center">
      <h2 class="section-subtitle">さあ、あなたの運命のサイクルを動かしましょう</h2>
      <p class="text-muted mb-3">
        占いは「当てる」ためだけのものではありません。<br>九星気学は、あなたの人生という航海をスムーズに進めるための「羅針盤」です。<br><br>
        今のあなたが必要としているエネルギーは何色ですか？<br>まずは、あなたの「本命星」をチェックすることから始めてみてください。
      </p>
      <a href="/fortune" class="btn-primary hero-btn">鑑定を始める</a>
    </div>
  </section>
</Layout>

<style>
/* --- スクロールアニメーション用のクラス追加 --- */
.fade-in-up {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  will-change: opacity, transform;
}
.fade-in-up.is-visible {
  opacity: 1;
  transform: translateY(0);
}
/* 複数要素を順番に出すためのディレイクラス */
.delay-1 { transition-delay: 0.1s; }
.delay-2 { transition-delay: 0.25s; }
.delay-3 { transition-delay: 0.4s; }


/* 共通ユーティリティ */
.text-center { text-align: center; }
.text-muted { color: var(--text-secondary); font-size: 0.95rem; }
.mb-3 { margin-bottom: 2rem; }

/* ヒーローセクション */
.hero {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center; position: relative; overflow: hidden;
  padding: 4rem 1.5rem;
}
.stars { position: absolute; inset: 0; pointer-events: none; }
.hero-content {
  position: relative; z-index: 1; max-width: 680px;
  animation: fadeInDown 1.5s ease-out;
}
.eyebrow {
  font-size: 0.8rem; letter-spacing: 0.3em;
  color: var(--gold); text-transform: uppercase; margin-bottom: 1.5rem;
  font-weight: 300;
}
.hero-title {
  font-family: var(--font-mincho);
  font-size: clamp(32px, 6vw, 56px);
  font-weight: 400; line-height: 1.4;
  margin-bottom: 1.5rem;
  background: linear-gradient(to right, #fff, var(--gold-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 40px rgba(212, 175, 55, 0.2);
}
.hero-desc {
  font-size: 1rem; color: var(--text-secondary);
  line-height: 2; margin-bottom: 3rem; letter-spacing: 0.05em;
}
.hero-note {
  margin-top: 1.5rem; font-size: 0.8rem; color: rgba(148, 163, 184, 0.7);
}
.scroll-indicator {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  color: var(--text-secondary); font-size: 0.75rem; letter-spacing: 0.2em;
  animation: bounce 2s infinite; text-transform: uppercase;
}

/* ボタンデザイン */
.btn-primary {
  display: inline-block;
  padding: 1rem 3rem;
  background: rgba(212, 175, 55, 0.1);
  border: 1px solid var(--gold);
  color: var(--gold-light);
  text-decoration: none;
  font-family: var(--font-mincho);
  font-size: 1.1rem;
  letter-spacing: 0.1em;
  border-radius: 30px;
  transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  backdrop-filter: blur(5px);
}
.btn-primary:hover {
  background: var(--gold);
  color: #000;
  box-shadow: 0 0 20px rgba(212, 175, 55, 0.4);
  transform: translateY(-2px);
}
.hero-btn { max-width: 280px; margin: 0 auto; display: block; }

/* コンテンツセクション */
.content-section {
  padding: 6rem 1.5rem;
  position: relative;
  z-index: 2;
}
.alternate-bg {
  background: linear-gradient(180deg, transparent 0%, rgba(20, 24, 39, 0.3) 50%, transparent 100%);
}
.content-inner { max-width: 800px; margin: 0 auto; }

/* 見出し */
.section-title {
  font-family: var(--font-mincho); font-size: clamp(24px, 4vw, 36px);
  font-weight: 400; margin-bottom: 2rem; line-height: 1.5; color: #fff;
}
.section-subtitle {
  font-family: var(--font-mincho); font-size: 1.5rem;
  color: var(--gold); margin-bottom: 1rem;
}
.lead-text {
  font-size: 1.1rem; font-weight: bold; line-height: 2; margin-bottom: 2rem;
}

/* グラスモーフィズムカード */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: 2.5rem 2rem;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

/* グリッドレイアウト */
.grid-cards {
  display: grid; gap: 1.5rem;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}
.grid-cards h4 {
  font-family: var(--font-mincho); color: var(--gold-light);
  margin: 0 0 1rem 0; font-size: 1.1rem;
}

/* 九星リスト */
.star-list {
  display: grid; gap: 1rem;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  margin: 0; padding: 0;
}
.star-item {
  background: rgba(255, 255, 255, 0.03);
  border-left: 2px solid var(--gold);
  padding: 1rem 1.5rem;
  border-radius: 0 8px 8px 0;
  transition: transform 0.3s ease, background 0.3s ease;
}
.star-item:hover { transform: translateX(5px); background: rgba(255, 255, 255, 0.05); }
.star-item dt {
  font-family: var(--font-mincho); font-size: 1.2rem;
  color: #fff; margin-bottom: 0.25rem;
}
.star-item dd { margin: 0; color: var(--text-secondary); font-size: 0.9rem; }

/* 機能紹介セクション */
.features { padding: 4rem 1.5rem; }
.features-inner {
  max-width: 900px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;
}
.feature-card { text-align: center; }
.feature-icon {
  font-size: 2.5rem; margin-bottom: 1.25rem; color: var(--gold);
  text-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
}
.feature-card h3 { font-family: var(--font-mincho); font-size: 1.2rem; margin-bottom: 1rem; }

/* CTAセクション */
.cta { padding: 4rem 1.5rem 8rem; }
.cta-inner { max-width: 700px; margin: 0 auto; padding: 4rem 2rem; }

/* アニメーション */
@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0) translateX(-50%); }
  40% { transform: translateY(-10px) translateX(-50%); }
  60% { transform: translateY(-5px) translateX(-50%); }
}
@keyframes twinkle {
  0% { opacity: 0.2; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); box-shadow: 0 0 10px rgba(255,255,255,0.5); }
  100% { opacity: 0.2; transform: scale(0.8); }
}
</style>

<script>
  // 星空の生成スクリプト
  const starsContainer = document.getElementById('stars');
  if (starsContainer) {
    const starCount = window.innerWidth < 768 ? 40 : 80;
    for (let i = 0; i < starCount; i++) {
      const s = document.createElement('div');
      const size = Math.random() * 2 + 0.5;
      s.style.cssText = `
        position: absolute;
        border-radius: 50%;
        background: #ffffff;
        width: ${size}px;
        height: ${size}px;
        top: ${Math.random() * 100}%;
        left: ${Math.random() * 100}%;
        opacity: ${Math.random() * 0.5 + 0.1};
        animation: twinkle ${3 + Math.random() * 4}s ease-in-out infinite;
        animation-delay: ${Math.random() * 5}s;
      `;
      starsContainer.appendChild(s);
    }
  }

  // スクロールフェードインのアニメーション制御 (Intersection Observer)
  const fadeElements = document.querySelectorAll('.fade-in-up');
  
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.15 // 要素が15%画面に入ったら発火
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        // 一度アニメーションしたら監視を解除する（何度もフェードインさせたい場合は下1行を削除）
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  fadeElements.forEach(el => {
    observer.observe(el);
  });
</script>