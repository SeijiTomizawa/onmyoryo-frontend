---
interface Props {
  title?: string;
}
const { title = "九星気学鑑定" } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="九星気学による本格占い鑑定サービス" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-mark">☯</span>
          <span class="logo-text">九星気学</span>
        </a>
        <nav class="nav" id="nav">
          <a href="/fortune">鑑定する</a>
          <a href="/mypage" id="nav-mypage" style="display:none">マイページ</a>
          <a href="/login" id="nav-login">ログイン</a>
          <button class="btn-outline" id="nav-logout" style="display:none" onclick="logout()">ログアウト</button>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <p>© 2026 九星気学鑑定</p>
    </footer>
  </body>
</html>

<style>
.header {
  border-bottom: 0.5px solid #ffffff15;
  padding: 0 1.5rem;
  position: sticky; top: 0; z-index: 100;
  background: #0d0d1acc;
  backdrop-filter: blur(12px);
}
.header-inner {
  max-width: 860px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 56px;
}
.logo {
  display: flex; align-items: center; gap: 8px;
  color: var(--text-primary); text-decoration: none;
}
.logo-mark { font-size: 20px; }
.logo-text {
  font-family: 'Shippori Mincho', serif;
  font-size: 16px; font-weight: 700;
  color: var(--gold);
}
.nav { display: flex; align-items: center; gap: 1.25rem; }
.nav a { font-size: 13px; color: var(--text-secondary); }
.nav a:hover { color: var(--text-primary); }
.footer {
  text-align: center; padding: 2rem;
  font-size: 12px; color: var(--text-muted);
  border-top: 0.5px solid #ffffff10;
  margin-top: 4rem;
}
</style>

<script>
function logout() {
  localStorage.removeItem('kyusei_token');
  localStorage.removeItem('kyusei_user');
  window.location.href = '/';
}
function updateNav() {
  const token = localStorage.getItem('kyusei_token');
  const login = document.getElementById('nav-login');
  const logout = document.getElementById('nav-logout');
  const mypage = document.getElementById('nav-mypage');
  if (token) {
    if (login) login.style.display = 'none';
    if (logout) logout.style.display = 'block';
    if (mypage) mypage.style.display = 'block';
  }
}
updateNav();
</script>
